<Window
    x:Class="TaskbarMonitor.Settings.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="4">

            <!-- Display Items -->
            <TextBlock Text="Display Items" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0"/>
            <Grid Margin="0,4,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/><RowDefinition Height="48"/>
                    <RowDefinition Height="48"/><RowDefinition Height="48"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Network Speed" FontSize="15"/>
                </StackPanel>
                <ToggleSwitch Grid.Row="0" Grid.Column="1" x:Name="NetworkToggle" IsOn="True" Toggled="OnNetworkToggled"/>

                <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="CPU" FontSize="15"/>
                    <TextBlock Text="Usage &amp; Temperature" FontSize="12" Opacity="0.5" Margin="0,1,0,0"/>
                </StackPanel>
                <ToggleSwitch Grid.Row="1" Grid.Column="1" x:Name="CpuToggle" IsOn="True" Toggled="OnCpuToggled"/>

                <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="GPU" FontSize="15"/>
                    <TextBlock Text="Usage &amp; Temperature" FontSize="12" Opacity="0.5" Margin="0,1,0,0"/>
                </StackPanel>
                <ToggleSwitch Grid.Row="2" Grid.Column="1" x:Name="GpuToggle" IsOn="True" Toggled="OnGpuToggled"/>

                <StackPanel Grid.Row="3" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Memory Usage" FontSize="15"/>
                </StackPanel>
                <ToggleSwitch Grid.Row="3" Grid.Column="1" x:Name="MemoryToggle" IsOn="True" Toggled="OnMemoryToggled"/>
            </Grid>

            <Border Height="1" Background="{ThemeResource CardBackgroundFillColorSecondary}" Margin="0,4"/>

            <!-- Appearance -->
            <TextBlock Text="Appearance" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0"/>
            <Grid Margin="0,4,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/><RowDefinition Height="48"/>
                    <RowDefinition Height="48"/><RowDefinition Height="48"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Theme" FontSize="15" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ThemeModeCombo"
                          SelectedIndex="0" SelectionChanged="OnThemeChanged"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Background Effect" FontSize="15" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="BackdropCombo"
                          SelectionChanged="OnBackdropChanged"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Label Font" FontSize="15" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="LabelFontCombo"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Value Font" FontSize="15" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ValueFontCombo"/>
            </Grid>

            <Border Height="1" Background="{ThemeResource CardBackgroundFillColorSecondary}" Margin="0,4"/>

            <!-- Position -->
            <TextBlock Text="Position" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0"/>
            <TextBlock Text="Widget placement on the taskbar" FontSize="12" Opacity="0.5" Margin="0,1,0,8"/>
            <RadioButtons x:Name="PositionRadio" Header="" SelectionChanged="OnPositionChanged">
                <RadioButton Content="Left"/>
                <RadioButton Content="Center"/>
                <RadioButton Content="Right"/>
            </RadioButtons>

        </StackPanel>
    </ScrollViewer>
</Window>
