<Window
    x:Class="TaskbarMonitor.Settings.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="4" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="105"/>
            <ColumnDefinition Width="105"/>
            <ColumnDefinition Width="105"/>
            <ColumnDefinition Width="105"/>
        </Grid.ColumnDefinitions>

        <!-- Network -->
        <Border x:Name="UiNetworkCard" Grid.Row="0" Grid.Column="0" CornerRadius="6" Background="#18808080" Padding="6,4" Margin="0,0,2,0">
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="&#x2191;" Foreground="#60B0FF" FontSize="13" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="UploadText" Text="0 B/s" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,1,0,0">
                    <TextBlock Text="&#x2193;" Foreground="#40D080" FontSize="13" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock x:Name="DownloadText" Text="0 B/s" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" FontFamily="Consolas"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- CPU -->
        <Border x:Name="UiCpuCard" Grid.Row="0" Grid.Column="1" CornerRadius="6" Background="#18808080" Padding="6,4" Margin="0,0,2,0">
            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="CPU" FontSize="11" Opacity="0.5"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock x:Name="CpuText" Text="0%" FontSize="13" FontWeight="SemiBold" FontFamily="Consolas" />
                    <TextBlock x:Name="CpuTempText" Margin="3,0,0,0" Text="--°C" FontSize="13" FontWeight="SemiBold" FontFamily="Consolas" Opacity="0.6"/>
                </StackPanel>
                <Grid x:Name="CpuBarGrid" Height="4" CornerRadius="2" Background="#40808080">
                    <Border x:Name="CpuBarFill" CornerRadius="2" Background="#60B0FF" HorizontalAlignment="Left" Width="0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- GPU -->
        <Border x:Name="UiGpuCard" Grid.Row="0" Grid.Column="2" CornerRadius="6" Background="#18808080" Padding="6,4" Margin="0,0,2,0">
            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="GPU" FontSize="11" Opacity="0.5"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock x:Name="GpuText" Text="0%" FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"/>
                    <TextBlock x:Name="GpuTempText" Margin="3,0,0,0" Text="--°C" FontSize="13" FontWeight="SemiBold" FontFamily="Consolas" Opacity="0.6"/>
                    <TextBlock x:Name="GpuPowerText" Margin="3,0,0,0" Text="--W" FontSize="13" FontWeight="SemiBold" FontFamily="Consolas" Opacity="0.6"/>
                </StackPanel>
                <Grid x:Name="GpuBarGrid" Height="4" CornerRadius="2" Background="#40808080">
                    <Border x:Name="GpuBarFill" CornerRadius="2" Background="#D06060" HorizontalAlignment="Left" Width="0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- RAM -->
        <Border x:Name="UiMemCard" Grid.Row="0" Grid.Column="3" CornerRadius="6" Background="#18808080" Padding="6,4" Margin="0,0,0,0">
            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="RAM" FontSize="11" Opacity="0.5"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock x:Name="MemText" Text="0 B" FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"/>
                    <TextBlock x:Name="MemPercentText" Text="0%" FontSize="13" FontWeight="SemiBold" FontFamily="Consolas" Opacity="0.6"/>
                </StackPanel>
                <Grid x:Name="MemBarGrid" Height="4" CornerRadius="2" Background="#40808080">
                    <Border x:Name="MemBarFill" CornerRadius="2" Background="#80C870" HorizontalAlignment="Left" Width="0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Context Menu Overlay -->
        <Popup x:Name="ContextPopup" IsLightDismissEnabled="True" Closed="OnContextMenuClosed">
            <Border x:Name="ContextMenuBorder" CornerRadius="8" Padding="4"
                    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1">
                <StackPanel MinWidth="180">
                    <Button x:Name="CtxSettingsBtn" Content="Settings"
                            Click="OnCtxSettingsClicked"
                            Height="36" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="12,0" FontSize="14"
                            Background="Transparent" BorderThickness="0"
                            CornerRadius="4">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource SystemControlHighlightAltBaseHighBrush}"/>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="CtxExitBtn" Content="Exit"
                            Click="OnCtxExitClicked"
                            Height="36" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="12,0" FontSize="14"
                            Background="Transparent" BorderThickness="0"
                            CornerRadius="4"/>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</Window>
