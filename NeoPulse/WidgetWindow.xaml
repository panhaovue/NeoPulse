<Window
    x:Class="NeoPulse.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel x:Name="RootPanel" Padding="4" Background="Transparent" Spacing="4"
                Orientation="Horizontal">

        <!-- Network -->
        <Border x:Name="UiNetworkCard" Width="105" Height="55" CornerRadius="6" Background="#18808080" Padding="6,4"
                Visibility="{Binding NetworkCardVisibility}">
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="&#x2191;" Foreground="#60B0FF" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding UploadText}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,1,0,0">
                    <TextBlock Text="&#x2193;" Foreground="#40D080" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DownloadText}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- CPU -->
        <Border x:Name="UiCpuCard" Width="105" Height="55" CornerRadius="6" Background="#18808080" Padding="6,4"
                Visibility="{Binding CpuCardVisibility}">
            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="CPU" FontSize="11" Opacity="0.5"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding CpuText}" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CpuTempText}" Margin="3,0,0,0" FontSize="13" FontWeight="SemiBold" Opacity="0.6"/>
                    <TextBlock Text="{Binding CpuPowerText}" Margin="3,0,0,0" FontSize="13" FontWeight="SemiBold" Opacity="0.6"/>
                </StackPanel>
                <Grid Height="4" CornerRadius="2" Background="{ThemeResource ControlStrokeColorSecondaryBrush}">
                    <Border x:Name="CpuBarFill" CornerRadius="2" Background="#60B0FF" HorizontalAlignment="Left" Width="{Binding CpuBarWidth}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- GPU -->
        <Border x:Name="UiGpuCard" Width="105" Height="55" CornerRadius="6" Background="#18808080" Padding="6,4"
                Visibility="{Binding GpuCardVisibility}">
            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="GPU" FontSize="11" Opacity="0.5"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding GpuText}" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding GpuTempText}" Margin="3,0,0,0" FontSize="13" FontWeight="SemiBold" Opacity="0.6"/>
                    <TextBlock Text="{Binding GpuPowerText}" Margin="3,0,0,0" FontSize="13" FontWeight="SemiBold" Opacity="0.6"/>
                </StackPanel>
                <Grid Height="4" CornerRadius="2" Background="{ThemeResource ControlStrokeColorSecondaryBrush}">
                    <Border x:Name="GpuBarFill" CornerRadius="2" Background="#D06060" HorizontalAlignment="Left" Width="{Binding GpuBarWidth}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- RAM -->
        <Border x:Name="UiMemCard" Width="105" Height="55" CornerRadius="6" Background="#18808080" Padding="6,4"
                Visibility="{Binding MemCardVisibility}">
            <StackPanel VerticalAlignment="Center" Spacing="3">
                <TextBlock Text="RAM" FontSize="11" Opacity="0.5"/>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="{Binding MemText}" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding MemPercentText}" FontSize="13" FontWeight="SemiBold" Opacity="0.6"/>
                </StackPanel>
                <Grid Height="4" CornerRadius="2" Background="{ThemeResource ControlStrokeColorSecondaryBrush}">
                    <Border x:Name="MemBarFill" CornerRadius="2" Background="#80C870" HorizontalAlignment="Left" Width="{Binding MemBarWidth}"/>
                </Grid>
            </StackPanel>
        </Border>

    <StackPanel.ContextFlyout>
        <MenuFlyout>
            <MenuFlyoutItem x:Name="CtxSettingsItem" Text="Settings" Click="OnCtxSettingsClicked"/>
            <MenuFlyoutItem x:Name="CtxExitItem" Text="Exit" Click="OnCtxExitClicked"/>
        </MenuFlyout>
    </StackPanel.ContextFlyout>

    </StackPanel>
</Window>
